rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /cars/{carId} {
      allow read: if true;
      allow write: if true;
    }

    match /locations/{locationId} {
      allow read: if true;
      allow write: if true;
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if true;
    }

    match /additionalOptions/{optionId} {
      allow read: if true;
      allow write: if true;
    }

    match /protection-details/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    match /pricing/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /adminSettings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
